<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YouTube Comments Search</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            margin: 0;
            padding: 20px;
            background-color: #f4f4f4;
        }
        .container {
            max-width: 800px;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        h1 {
            color: #333;
        }
        #searchForm {
            margin-bottom: 20px;
        }
        input[type="text"], select {
            width: 100%;
            padding: 8px;
            margin-bottom: 10px;
        }
        button {
            background-color: #4CAF50;
            color: white;
            padding: 10px 15px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        button:hover {
            background-color: #45a049;
        }
        #results {
            background-color: #fff;
            border: 1px solid #ddd;
            padding: 10px;
            border-radius: 4px;
        }
        .comment {
            border-bottom: 1px solid #eee;
            padding: 10px 0;
        }
        .comment:last-child {
            border-bottom: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>YouTube Comments Search</h1>
        <form id="searchForm">
            <input type="text" id="authorInput" placeholder="Filter by author...">
            <input type="text" id="keywordInput" placeholder="Filter by keyword...">
            <button type="submit">Search</button>
        </form>
        <div id="results"></div>
    </div>

    <script>
        let comments = [];

        // Load the JSON data
        fetch('data_chunk_1.json')
            .then(response => response.json())
            .then(data => {
                comments = data;
                console.log('Data loaded successfully');
            })
            .catch(error => console.error('Error loading the JSON data:', error));

        // Search function
        function searchComments(author, keyword) {
            return comments.filter(comment => {
                const authorMatch = !author || comment.Author.toLowerCase().includes(author.toLowerCase());
                const keywordMatch = !keyword || comment.Message.toLowerCase().includes(keyword.toLowerCase());
                return authorMatch && keywordMatch;
            });
        }

        // Display results
        function displayResults(results) {
            const resultsDiv = document.getElementById('results');
            resultsDiv.innerHTML = '';

            if (results.length === 0) {
                resultsDiv.innerHTML = '<p>No results found.</p>';
                return;
            }

            results.forEach(comment => {
                const commentDiv = document.createElement('div');
                commentDiv.className = 'comment';
                commentDiv.innerHTML = `
                    <p><strong>Author:</strong> ${comment.Author}</p>
                    <p><strong>Message:</strong> ${comment.Message}</p>
                    <p><strong>Timestamp:</strong> ${comment.Timestamp}</p>
                `;
                resultsDiv.appendChild(commentDiv);
            });
        }

        // Event listener for form submission
        document.getElementById('searchForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const author = document.getElementById('authorInput').value;
            const keyword = document.getElementById('keywordInput').value;
            const results = searchComments(author, keyword);
            displayResults(results);
        });
    </script>
</body>
</html>